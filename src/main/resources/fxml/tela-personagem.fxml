<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #16213e);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baquara.gui.controller.TelaPersonagemController">
    <children>
        <VBox alignment="CENTER" spacing="30.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>
                <Label alignment="CENTER" text="ESCOLHA SEU PERSONAGEM" textFill="YELLOW">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Label>

                <Label text="Cada personagem tem habilidades únicas e uma rota especial!" textFill="WHITE">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <GridPane alignment="CENTER" hgap="20.0" vgap="20.0">
                    <children>
                        <!-- Paladino -->
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 48px;" text="🛡️" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="PALADINO" textFill="WHITE" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaa;" text="Vida: 150 | Defesa: 25" />
                                <Button fx:id="btnPaladino" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="ESCOLHER" />
                            </children>
                        </VBox>

                        <!-- Guerreiro -->
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 48px;" text="⚔️" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="GUERREIRO" textFill="WHITE" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaa;" text="Vida: 140 | Defesa: 18" />
                                <Button fx:id="btnGuerreiro" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="ESCOLHER" />
                            </children>
                        </VBox>

                        <!-- Caçadora -->
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 48px;" text="🌿" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="CAÇADORA" textFill="WHITE" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaa;" text="Vida: 110 | Ataque: 30" />
                                <Button fx:id="btnCacadora" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="ESCOLHER" />
                            </children>
                        </VBox>

                        <!-- Sábio -->
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 48px;" text="📚" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="SÁBIO" textFill="WHITE" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaa;" text="Vida: 100 | Mana: 100" />
                                <Button fx:id="btnSabio" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="ESCOLHER" />
                            </children>
                        </VBox>

                        <!-- Arcanista -->
                        <VBox alignment="CENTER" spacing="10.0" style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 15; -fx-padding: 20;">
                            <children>
                                <Label style="-fx-font-size: 48px;" text="🔮" />
                                <Label style="-fx-font-size: 18px; -fx-font-weight: bold;" text="ARCANISTA" textFill="WHITE" />
                                <Label style="-fx-font-size: 12px; -fx-text-fill: #aaa;" text="Vida: 95 | Poder: 100" />
                                <Button fx:id="btnArcanista" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-size: 14px;" text="ESCOLHER" />
                            </children>
                        </VBox>
                    </children>
                </GridPane>

                <Button fx:id="btnVoltar" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 14px; -fx-padding: 10px 30px;" text="◀️ VOLTAR" />
            </children>
            <padding>
                <Insets bottom="30.0" left="30.0" right="30.0" top="30.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>