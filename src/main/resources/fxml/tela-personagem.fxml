<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baquara.gui.controllers.TelaPersonagemController">
    <content>
        <VBox spacing="20.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #0a0a1a); -fx-padding: 30;">

            <Label alignment="CENTER" style="-fx-font-size: 36px; -fx-font-weight: bold;" text="ESCOLHA SEU DESTINO" textFill="#FFD700" />
            <Label fx:id="lblSubtitulo" alignment="CENTER" style="-fx-font-size: 16px;" text="Cada porta leva a uma rota diferente..." textFill="WHITE" />

            <!-- ========== PORTAS DOS PERSONAGENS NORMAIS ========== -->
            <GridPane fx:id="gridNormais" alignment="CENTER" hgap="30.0" vgap="30.0" visible="true" managed="true">

                <!-- Porta Paladino -->
                <VBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="0">
                    <Button fx:id="btnPaladino" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <graphic>
                            <VBox alignment="CENTER" spacing="5.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.5, 0, 0);">
                                <Label style="-fx-font-size: 80px;" text="🚪" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2a2a4a; -fx-padding: 5 15; -fx-background-radius: 20;" text="PALADINO" textFill="#FFD700" />
                                <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 8;" spacing="3.0">
                                    <Label style="-fx-font-size: 11px;" text="❤️ 150 vida" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🛡️ Defesa 25" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🙏 Poder Divino" textFill="#ccc" />
                                </VBox>
                            </VBox>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Porta Guerreiro -->
                <VBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="0">
                    <Button fx:id="btnGuerreiro" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <graphic>
                            <VBox alignment="CENTER" spacing="5.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.5, 0, 0);">
                                <Label style="-fx-font-size: 80px;" text="🚪" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2a2a4a; -fx-padding: 5 15; -fx-background-radius: 20;" text="GUERREIRO" textFill="#FFD700" />
                                <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 8;" spacing="3.0">
                                    <Label style="-fx-font-size: 11px;" text="❤️ 140 vida" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🛡️ Defesa 18" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="💪 Espírito de Luta" textFill="#ccc" />
                                </VBox>
                            </VBox>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Porta Caçadora -->
                <VBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="2" GridPane.rowIndex="0">
                    <Button fx:id="btnCacadora" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <graphic>
                            <VBox alignment="CENTER" spacing="5.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.5, 0, 0);">
                                <Label style="-fx-font-size: 80px;" text="🚪" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2a2a4a; -fx-padding: 5 15; -fx-background-radius: 20;" text="CAÇADORA" textFill="#FFD700" />
                                <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 8;" spacing="3.0">
                                    <Label style="-fx-font-size: 11px;" text="❤️ 110 vida" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="⚔️ Ataque 30" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🏹 Penetração" textFill="#ccc" />
                                </VBox>
                            </VBox>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Porta Sábio -->
                <VBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="0" GridPane.rowIndex="1">
                    <Button fx:id="btnSabio" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <graphic>
                            <VBox alignment="CENTER" spacing="5.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.5, 0, 0);">
                                <Label style="-fx-font-size: 80px;" text="🚪" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2a2a4a; -fx-padding: 5 15; -fx-background-radius: 20;" text="SÁBIO" textFill="#FFD700" />
                                <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 8;" spacing="3.0">
                                    <Label style="-fx-font-size: 11px;" text="❤️ 100 vida" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🛡️ Defesa 14" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="💙 Mana 100" textFill="#ccc" />
                                </VBox>
                            </VBox>
                        </graphic>
                    </Button>
                </VBox>

                <!-- Porta Arcanista -->
                <VBox alignment="CENTER" spacing="10.0" GridPane.columnIndex="1" GridPane.rowIndex="1">
                    <Button fx:id="btnArcanista" style="-fx-background-color: transparent; -fx-padding: 0;">
                        <graphic>
                            <VBox alignment="CENTER" spacing="5.0" style="-fx-effect: dropshadow(gaussian, rgba(0,0,0,0.5), 10, 0.5, 0, 0);">
                                <Label style="-fx-font-size: 80px;" text="🚪" />
                                <Label style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #2a2a4a; -fx-padding: 5 15; -fx-background-radius: 20;" text="ARCANISTA" textFill="#FFD700" />
                                <VBox style="-fx-background-color: rgba(255,255,255,0.1); -fx-background-radius: 10; -fx-padding: 8;" spacing="3.0">
                                    <Label style="-fx-font-size: 11px;" text="❤️ 95 vida" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="🛡️ Defesa 8" textFill="#ccc" />
                                    <Label style="-fx-font-size: 11px;" text="✨ Poder Arcano" textFill="#ccc" />
                                </VBox>
                            </VBox>
                        </graphic>
                    </Button>
                </VBox>

            </GridPane>

            <!-- ========== PORTA SECRETA (SÓ APARECE PARA Rudá) ========== -->
            <VBox fx:id="painelSecreto" alignment="CENTER" spacing="20.0" visible="false" managed="false">
                <Label style="-fx-font-size: 20px; -fx-font-weight: bold;" text="🔮 UMA PORTA MISTERIOSA APARECEU! 🔮" textFill="#9C27B0" />

                <Button fx:id="btnRotaSecreta" style="-fx-background-color: transparent; -fx-padding: 0;">
                    <graphic>
                        <VBox alignment="CENTER" spacing="10.0">
                            <Label style="-fx-font-size: 100px;" text="🚪🔮" />
                            <Label style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-background-color: #9C27B0; -fx-padding: 8 25; -fx-background-radius: 25;" text="🥋 RODA DE CAPOEIRA 🥋" textFill="#FFD700" />
                            <VBox style="-fx-background-color: rgba(156,39,176,0.3); -fx-background-radius: 15; -fx-padding: 12;" spacing="5.0" alignment="CENTER">
                                <Label style="-fx-font-size: 12px;" text="⚔️ Modo Especial: Capoeira" textFill="#E1BEE7" />
                                <Label style="-fx-font-size: 12px;" text="🎵 Enfrente os 9 Mestres" textFill="#E1BEE7" />
                                <Label style="-fx-font-size: 12px;" text="🦗 Derrote o Besouro Mangangá" textFill="#E1BEE7" />
                                <Label style="-fx-font-size: 12px;" text="👑 Torne-se uma lenda!" textFill="#FFD700" />
                            </VBox>
                        </VBox>
                    </graphic>
                </Button>
            </VBox>

            <Button fx:id="btnVoltar" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 16px; -fx-padding: 10px 30px; -fx-background-radius: 8;" text="◀️ VOLTAR" />

        </VBox>
    </content>
</ScrollPane>