<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #1a3a2a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baquara.gui.controllers.TelaBatalhaController">

    <children>

        <!-- ==================== TÍTULO ==================== -->
        <Label layoutX="300.0" layoutY="10.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="⚔️ BAQUARA ⚔️" textFill="#FFD700" />

        <Label fx:id="lblTurno" layoutX="500.0" layoutY="15.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #333; -fx-padding: 5 15; -fx-background-radius: 20;" text="⚔️ SEU TURNO ⚔️" textFill="#FFD700" />

        <!-- ==================== INIMIGO (Sprite + Status lado a lado) ==================== -->
        <HBox alignment="CENTER" layoutX="530.0" layoutY="50.0" spacing="15.0">
            <children>
                <!-- Sprite do Inimigo -->
                <VBox alignment="CENTER" prefHeight="90.0" prefWidth="90.0" style="-fx-background-color: #2a2a4a; -fx-background-radius: 10; -fx-border-color: #ff4444; -fx-border-radius: 10; -fx-border-width: 2;">
                    <children>
                        <Label fx:id="lblInimigoSprite" style="-fx-font-size: 48px;" text="👾" />
                    </children>
                </VBox>

                <!-- Status do Inimigo (ao lado do sprite) -->
                <VBox spacing="3.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 8; -fx-padding: 8 12;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="lblInimigoNome" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="INIMIGO" textFill="WHITE" />
                                <Label fx:id="lblInimigoNivel" style="-fx-font-size: 10px;" text="Lv.1" textFill="#ccc" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="barraInimigoVida" prefWidth="160.0" progress="1.0" style="-fx-accent: #ff4444;" />
                        <Label fx:id="lblInimigoVida" style="-fx-font-size: 10px;" text="HP: 100/100" textFill="WHITE" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- ==================== JOGADOR (Sprite + Status lado a lado) ==================== -->
        <HBox alignment="CENTER" layoutX="80.0" layoutY="380.0" spacing="15.0">
            <children>
                <!-- Status do Jogador (ao lado do sprite) -->
                <VBox spacing="3.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 8; -fx-padding: 8 12;">
                    <children>
                        <HBox alignment="CENTER_LEFT" spacing="10.0">
                            <children>
                                <Label fx:id="lblJogadorNome" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="JOGADOR" textFill="WHITE" />
                                <Label fx:id="lblJogadorNivel" style="-fx-font-size: 10px;" text="Lv.1" textFill="#ccc" />
                            </children>
                        </HBox>
                        <ProgressBar fx:id="barraJogadorVida" prefWidth="160.0" progress="1.0" style="-fx-accent: #44ff44;" />
                        <Label fx:id="lblJogadorVida" style="-fx-font-size: 10px;" text="HP: 100/100" textFill="WHITE" />
                        <Label fx:id="lblJogadorAtributo" style="-fx-font-size: 10px;" text="✨ Poder: 100" textFill="#aaa" />
                    </children>
                </VBox>

                <!-- Sprite do Jogador -->
                <VBox alignment="CENTER" prefHeight="90.0" prefWidth="90.0" style="-fx-background-color: #2a2a4a; -fx-background-radius: 10; -fx-border-color: #44ff44; -fx-border-radius: 10; -fx-border-width: 2;">
                    <children>
                        <Label fx:id="lblJogadorSprite" style="-fx-font-size: 48px;" text="⚔️" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- ==================== CAIXA DE DIÁLOGO ==================== -->
        <VBox layoutX="20.0" layoutY="430.0" prefWidth="400.0" prefHeight="140.0" style="-fx-background-color: rgba(0,0,0,0.85); -fx-background-radius: 15; -fx-border-color: #FFD700; -fx-border-radius: 15; -fx-border-width: 2;">
            <children>
                <TextArea fx:id="txtDialogo" prefHeight="100.0" style="-fx-font-size: 13px; -fx-background-color: transparent; -fx-text-fill: #FFD700; -fx-border-width: 0;" wrapText="true" editable="false" />
                <Label fx:id="lblTurnoMsg" style="-fx-font-size: 11px; -fx-text-fill: #aaa;" text="⚔️ Escolha sua ação! ⚔️" />
            </children>
            <padding>
                <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
            </padding>
        </VBox>

        <!-- ==================== MENU DE AÇÕES ==================== -->
        <VBox layoutX="440.0" layoutY="430.0" spacing="10.0" prefWidth="180.0">
            <children>
                <Button fx:id="btnAtacar" style="-fx-background-color: #306830; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8;" text="⚔️ ATACAR" />
                <Button fx:id="btnHabilidade" style="-fx-background-color: #8B4513; -fx-text-fill: white; -fx-font-size: 16px; -fx-font-weight: bold; -fx-padding: 10px 20px; -fx-background-radius: 8;" text="🌟 HABILIDADE" />
                <Label fx:id="lblCooldown" style="-fx-font-size: 11px; -fx-text-fill: #FF9800;" text="✨ Habilidade disponível!" />
            </children>
        </VBox>

        <!-- ==================== PAINEL DE PERGUNTA ==================== -->
        <VBox fx:id="painelPergunta" layoutX="20.0" layoutY="430.0" prefWidth="400.0" prefHeight="140.0" spacing="8.0" style="-fx-background-color: rgba(0,0,0,0.9); -fx-background-radius: 15; -fx-border-color: #FFD700; -fx-border-radius: 15; -fx-border-width: 2;" visible="false" managed="false">
            <children>
                <Label fx:id="lblDificuldade" style="-fx-font-size: 11px;" text="⭐ Dificuldade: Fácil" textFill="#FFD700" />

                <ScrollPane fitToWidth="true" prefHeight="60.0" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <TextArea fx:id="txtPergunta" style="-fx-font-size: 12px; -fx-background-color: #111; -fx-text-fill: white; -fx-border-width: 0; -fx-control-inner-background: #111;" wrapText="true" editable="false" />
                    </content>
                </ScrollPane>

                <!-- Alternativas -->
                <VBox fx:id="painelAlternativas" spacing="5.0" />

                <!-- Lacuna -->
                <HBox fx:id="painelLacuna" spacing="8.0" alignment="CENTER" visible="false" managed="false">
                    <children>
                        <Label text="Resposta:" textFill="WHITE" />
                        <TextField fx:id="txtRespostaLacuna" promptText="Digite sua resposta..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 5;" />
                        <Button fx:id="btnEnviarLacuna" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="RESPONDER" />
                    </children>
                </HBox>

                <Button fx:id="btnVoltarMenu" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 5px 15px; -fx-background-radius: 8;" text="◀️ VOLTAR" />
            </children>
            <padding>
                <Insets bottom="10.0" left="12.0" right="12.0" top="10.0" />
            </padding>
        </VBox>

    </children>
</AnchorPane>