<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: linear-gradient(to bottom, #1a1a2e, #16213e);" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baquara.gui.controllers.TelaInicialController">
    <children>
        <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
            <children>

                <!-- TÍTULO PRINCIPAL -->
                <Label alignment="CENTER" text="BAQUARA" textFill="YELLOW">
                    <font>
                        <Font name="System Bold" size="48.0" />
                    </font>
                </Label>

                <!-- SUBTÍTULO -->
                <Label alignment="CENTER" text="BATALHA DO SABER" textFill="WHITE">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Label>

                <!-- LABEL "Digite seu nome" -->
                <Label text="Digite seu nome:" textFill="WHITE">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>

                <!-- CAMPO DE TEXTO PARA O NOME -->
                <TextField fx:id="txtNome" maxWidth="300.0" promptText="Seu nome aqui" style="-fx-font-size: 14px; -fx-padding: 10px;">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </TextField>

                <!-- BOTÃO JOGAR -->
                <Button fx:id="btnJogar" style="-fx-font-size: 16px; -fx-padding: 10px 30px; -fx-background-color: #4CAF50; -fx-text-fill: white;" text="▶️ JOGAR">
                    <VBox.margin>
                        <Insets top="20.0" />
                    </VBox.margin>
                </Button>

                <!-- ⭐ NOVO BOTÃO RANKING ⭐ -->
                <Button fx:id="btnRanking" style="-fx-font-size: 16px; -fx-padding: 10px 30px; -fx-background-color: #2196F3; -fx-text-fill: white;" text="🏆 RANKING">
                    <VBox.margin>
                        <Insets top="10.0" />
                    </VBox.margin>
                </Button>

                <!-- BOTÃO SAIR -->
                <Button fx:id="btnSair" style="-fx-font-size: 16px; -fx-padding: 10px 30px; -fx-background-color: #f44336; -fx-text-fill: white;" text="❌ SAIR" />

            </children>
            <padding>
                <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
            </padding>
        </VBox>
    </children>
</AnchorPane>