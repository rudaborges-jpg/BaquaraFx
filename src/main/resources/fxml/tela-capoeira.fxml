<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #1a3a2a;" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.baquara.gui.controllers.TelaCapoeiraController">

    <children>

        <!-- TÍTULO -->
        <Label layoutX="280.0" layoutY="10.0" style="-fx-font-size: 24px; -fx-font-weight: bold;" text="🥋 RODA DE CAPOEIRA 🥋" textFill="#FFD700" />
        <Label fx:id="lblTurno" layoutX="520.0" layoutY="15.0" style="-fx-font-size: 14px; -fx-font-weight: bold; -fx-background-color: #333; -fx-padding: 5 15; -fx-background-radius: 20;" text="🥋 RODADA 1 🥋" textFill="#FFD700" />

        <!-- INIMIGO -->
        <HBox alignment="CENTER" layoutX="500.0" layoutY="60.0" spacing="15.0">
            <children>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: #2a2a4a; -fx-background-radius: 10; -fx-border-color: #ff4444; -fx-border-radius: 10; -fx-border-width: 2;">
                    <children>
                        <Label fx:id="lblInimigoSprite" style="-fx-font-size: 56px;" text="🥋" />
                    </children>
                </VBox>
                <VBox spacing="3.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 8; -fx-padding: 8 12;">
                    <children>
                        <Label fx:id="lblInimigoNome" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="MESTRE" textFill="WHITE" />
                        <Label fx:id="lblInimigoNivel" style="-fx-font-size: 10px;" text="Estágio 1" textFill="#ccc" />
                        <ProgressBar fx:id="barraInimigoVida" prefWidth="160.0" progress="1.0" style="-fx-accent: #ff4444;" />
                        <Label fx:id="lblInimigoVida" style="-fx-font-size: 10px;" text="Vida: 100/100" textFill="WHITE" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- JOGADOR (MAIS ALTO) -->
        <HBox alignment="CENTER" layoutX="80.0" layoutY="300.0" spacing="15.0">
            <children>
                <VBox spacing="3.0" style="-fx-background-color: rgba(0,0,0,0.7); -fx-background-radius: 8; -fx-padding: 8 12;">
                    <children>
                        <Label fx:id="lblJogadorNome" style="-fx-font-size: 14px; -fx-font-weight: bold;" text="CAPOEIRISTA" textFill="WHITE" />
                        <Label fx:id="lblJogadorNivel" style="-fx-font-size: 10px;" text="Título" textFill="#ccc" />
                        <ProgressBar fx:id="barraJogadorVida" prefWidth="160.0" progress="1.0" style="-fx-accent: #44ff44;" />
                        <Label fx:id="lblJogadorVida" style="-fx-font-size: 10px;" text="Vida: 120/120" textFill="WHITE" />
                        <Label fx:id="lblJogadorGinga" style="-fx-font-size: 10px;" text="🌀 Ginga: 100/100" textFill="#aaa" />
                        <Label fx:id="lblEsquivas" style="-fx-font-size: 10px;" text="🔄 Esquivas: 2/2" textFill="#aaa" />
                    </children>
                </VBox>
                <VBox alignment="CENTER" prefHeight="100.0" prefWidth="100.0" style="-fx-background-color: #2a2a4a; -fx-background-radius: 10; -fx-border-color: #44ff44; -fx-border-radius: 10; -fx-border-width: 2;">
                    <children>
                        <Label fx:id="lblJogadorSprite" style="-fx-font-size: 56px;" text="🥋" />
                    </children>
                </VBox>
            </children>
        </HBox>

        <!-- PAINEL INFERIOR - DIÁLOGO E PERGUNTAS -->
        <VBox layoutX="20.0" layoutY="430.0" spacing="10.0" prefWidth="550.0" AnchorPane.bottomAnchor="20.0" AnchorPane.leftAnchor="20.0">
            <children>
                <!-- DIÁLOGO -->
                <ScrollPane fitToWidth="true" prefHeight="100.0" style="-fx-background: #000; -fx-background-color: #000; -fx-background-radius: 10; -fx-border-color: #FFD700; -fx-border-radius: 10;">
                    <content>
                        <TextArea fx:id="txtDialogo" style="-fx-font-size: 12px; -fx-background-color: #000; -fx-text-fill: #0f0; -fx-border-width: 0;" wrapText="true" editable="false" />
                    </content>
                </ScrollPane>

                <!-- DIFICULDADE -->
                <Label fx:id="lblDificuldade" style="-fx-font-size: 11px;" text="⭐ Aguardando ação..." textFill="#FFD700" />

                <!-- PERGUNTA -->
                <TextArea fx:id="txtPergunta" prefHeight="60.0" style="-fx-font-size: 13px; -fx-background-color: #111; -fx-text-fill: white; -fx-border-color: #FFD700; -fx-border-radius: 5;" wrapText="true" editable="false" />

                <!-- ALTERNATIVAS -->
                <ScrollPane fitToWidth="true" prefHeight="100.0" style="-fx-background: transparent; -fx-background-color: transparent;">
                    <content>
                        <VBox fx:id="painelAlternativas" spacing="5.0" />
                    </content>
                </ScrollPane>

                <!-- LACUNA -->
                <HBox fx:id="painelLacuna" spacing="8.0" alignment="CENTER" visible="false" managed="false">
                    <children>
                        <Label text="Resposta:" textFill="WHITE" />
                        <TextField fx:id="txtRespostaLacuna" promptText="Digite sua resposta..." HBox.hgrow="ALWAYS" style="-fx-background-radius: 5;" />
                        <Button fx:id="btnEnviarLacuna" style="-fx-background-color: #4CAF50; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5;" text="RESPONDER" />
                    </children>
                </HBox>

                <Label fx:id="lblTurnoMsg" style="-fx-font-size: 11px; -fx-text-fill: #aaa;" text="🥋 Escolha seu movimento ao lado! 🥋" />
            </children>
        </VBox>

        <!-- MENU DE AÇÕES (LADO DIREITO) -->
        <VBox layoutX="590.0" layoutY="430.0" spacing="10.0" prefWidth="180.0" AnchorPane.bottomAnchor="20.0" AnchorPane.rightAnchor="20.0">
            <children>
                <Button fx:id="btnBasico" style="-fx-background-color: #306830; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12px 15px; -fx-background-radius: 8;" text="🔄 GINGA BÁSICA" maxWidth="Infinity" />
                <Button fx:id="btnDificil" style="-fx-background-color: #8B4513; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12px 15px; -fx-background-radius: 8;" text="💫 ATAQUE DIFÍCIL" maxWidth="Infinity" />
                <Button fx:id="btnCombinado" style="-fx-background-color: #9C27B0; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12px 15px; -fx-background-radius: 8;" text="🔥 COMBINAÇÃO MORTAL" maxWidth="Infinity" />
                <Button fx:id="btnEsquiva" style="-fx-background-color: #2196F3; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 12px 15px; -fx-background-radius: 8;" text="🌀 ESQUIVA" maxWidth="Infinity" />
                <Button fx:id="btnVoltarMenu" style="-fx-background-color: #f44336; -fx-text-fill: white; -fx-font-size: 12px; -fx-padding: 8px 15px; -fx-background-radius: 8;" text="◀️ CANCELAR" maxWidth="Infinity" />
            </children>
        </VBox>

    </children>
</AnchorPane>